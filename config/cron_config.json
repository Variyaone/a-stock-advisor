    },
    "light": {
      "max_cpu_percent": 25,
      "max_memory_mb": 512,
      "description": "低负载，IO密集型"
    },
    "medium": {
      "max_cpu_percent": 50,
      "max_memory_mb": 1024,
      "description": "中等负载，计算密集型"
    },
